# Copy to secrets.toml for local use (secrets.toml is gitignored).
# On Streamlit Community Cloud, add the same keys under App settings → Secrets.

# Optional LLM assist (Validate / Configure). Prefer Groq or Gemini (free tiers).
GROQ_API_KEY = ""
GEMINI_API_KEY = ""
OPENAI_API_KEY = ""

# Optional shared password gate for Cloud / LAN deployments.
# Leave empty (or omit) so the app runs without a sign-in prompt.
CROSS_SECTION_AUTH_PASSWORD = ""

# Legacy lowercase alias also accepted for OpenAI:
# openai_api_key = ""
